{
  "uid": "docker-containers",
  "title": "Docker Containers",
  "description": "Container CPU, Memory, Network — powered by cAdvisor",
  "tags": ["docker", "containers", "monitoring"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(container_cpu_usage_seconds_total{image!=\"\"}, name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Running Containers",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "count(container_last_seen{image!=\"\",name!=\"\"})", "legendFormat": "Containers" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 2, "type": "stat", "title": "Total Container CPU",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(irate(container_cpu_usage_seconds_total{image!=\"\",name!=\"\"}[5m])) * 100", "legendFormat": "Total CPU %" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 3, "type": "stat", "title": "Total Container Memory",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": { "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2147483648 }, { "color": "red", "value": 4294967296 }] } }
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(container_memory_usage_bytes{image!=\"\",name!=\"\"})", "legendFormat": "Total Memory" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 4, "type": "stat", "title": "Container Network RX/TX",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto", "orientation": "horizontal" },
      "fieldConfig": {
        "defaults": { "unit": "Bps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(irate(container_network_receive_bytes_total{image!=\"\"}[5m]))", "legendFormat": "RX" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(irate(container_network_transmit_bytes_total{image!=\"\"}[5m]))", "legendFormat": "TX" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 5, "type": "timeseries", "title": "CPU Usage per Container",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 9 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "right" } },
      "fieldConfig": {
        "defaults": { "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "expr": "irate(container_cpu_usage_seconds_total{image!=\"\",name=~\"$container\"}[5m]) * 100",
        "legendFormat": "{{name}}"
      }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 6, "type": "timeseries", "title": "Memory Usage per Container",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 9 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "right" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "expr": "container_memory_usage_bytes{image!=\"\",name=~\"$container\"}",
        "legendFormat": "{{name}}"
      }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 7, "type": "timeseries", "title": "Network RX per Container",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "expr": "irate(container_network_receive_bytes_total{image!=\"\",name=~\"$container\"}[5m])",
        "legendFormat": "{{name}}"
      }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 8, "type": "timeseries", "title": "Network TX per Container",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "expr": "irate(container_network_transmit_bytes_total{image!=\"\",name=~\"$container\"}[5m])",
        "legendFormat": "{{name}}"
      }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 9, "type": "table", "title": "Container Summary Table",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 7 },
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "displayName": "CPU %", "desc": true }] },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CPU %" }, "properties": [{ "id": "unit", "value": "percent" }, { "id": "decimals", "value": 2 }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 50 }] } }] },
          { "matcher": { "id": "byName", "options": "Memory" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 536870912 }, { "color": "red", "value": 1073741824 }] } }] }
        ]
      },
      "transformations": [{ "id": "merge", "options": {} }],
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "irate(container_cpu_usage_seconds_total{image!=\"\",name!=\"\"}[5m]) * 100", "legendFormat": "{{name}}", "instant": true, "refId": "CPU" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "container_memory_usage_bytes{image!=\"\",name!=\"\"}", "legendFormat": "{{name}}", "instant": true, "refId": "MEM" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    }
  ]
}
