{
  "uid": "coderz-eshop",
  "title": "eShop API — Full Stack",
  "tags": ["eshop", "coderz"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "row", "title": "Live Metrics (Prometheus)", "gridPos": {"h":1,"w":24,"x":0,"y":0}
    },
    {
      "id": 2, "type": "stat", "title": "Requests / sec",
      "gridPos": {"h":4,"w":4,"x":0,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"area"},
      "fieldConfig": {"defaults": {"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":200}]},"unit":"reqps"}},
      "targets": [{"expr":"sum(rate(http_requests_received_total{job=\"eshop-publicapi\"}[1m]))","legendFormat":"req/s"}]
    },
    {
      "id": 3, "type": "stat", "title": "P95 Latency",
      "gridPos": {"h":4,"w":4,"x":4,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults": {"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":500},{"color":"red","value":2000}]},"unit":"ms"}},
      "targets": [{"expr":"histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"eshop-publicapi\"}[5m])) by (le)) * 1000","legendFormat":"p95"}]
    },
    {
      "id": 4, "type": "stat", "title": "Error Rate %",
      "gridPos": {"h":4,"w":4,"x":8,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults": {"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":5}]},"unit":"percent"}},
      "targets": [{"expr":"sum(rate(http_requests_received_total{job=\"eshop-publicapi\",code=~\"5..\"}[5m])) / sum(rate(http_requests_received_total{job=\"eshop-publicapi\"}[5m])) * 100","legendFormat":"error%"}]
    },
    {
      "id": 5, "type": "stat", "title": "Active Requests",
      "gridPos": {"h":4,"w":4,"x":12,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults": {"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"yellow","value":20},{"color":"red","value":100}]}}},
      "targets": [{"expr":"sum(http_requests_in_progress{job=\"eshop-publicapi\"})","legendFormat":"active"}]
    },
    {
      "id": 6, "type": "stat", "title": "API Status",
      "gridPos": {"h":4,"w":4,"x":16,"y":1},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults": {"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"red","value":null},{"color":"green","value":1}]},"mappings":[{"type":"value","options":{"1":{"text":"UP","color":"green"},"0":{"text":"DOWN","color":"red"}}}]}},
      "targets": [{"expr":"up{job=\"eshop-publicapi\"}","legendFormat":"status"}]
    },
    {
      "id": 10, "type": "row", "title": "Request Throughput", "gridPos": {"h":1,"w":24,"x":0,"y":5}
    },
    {
      "id": 11, "type": "timeseries", "title": "Requests/sec by Endpoint",
      "gridPos": {"h":8,"w":12,"x":0,"y":6},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {"defaults": {"unit":"reqps","custom":{"lineWidth":2}}},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "targets": [{"expr":"sum by (action) (rate(http_requests_received_total{job=\"eshop-publicapi\"}[2m]))","legendFormat":"{{action}}"}]
    },
    {
      "id": 12, "type": "timeseries", "title": "HTTP Status Breakdown",
      "gridPos": {"h":8,"w":12,"x":12,"y":6},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {"defaults": {"unit":"reqps","custom":{"lineWidth":2}}},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "targets": [{"expr":"sum by (code) (rate(http_requests_received_total{job=\"eshop-publicapi\"}[2m]))","legendFormat":"HTTP {{code}}"}]
    },
    {
      "id": 20, "type": "row", "title": "Latency Percentiles", "gridPos": {"h":1,"w":24,"x":0,"y":14}
    },
    {
      "id": 21, "type": "timeseries", "title": "Latency Percentiles (p50 / p95 / p99)",
      "gridPos": {"h":8,"w":24,"x":0,"y":15},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {"defaults": {"unit":"ms","custom":{"lineWidth":2}}},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "targets": [
        {"expr":"histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"eshop-publicapi\"}[5m])) by (le)) * 1000","legendFormat":"p50"},
        {"expr":"histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"eshop-publicapi\"}[5m])) by (le)) * 1000","legendFormat":"p95"},
        {"expr":"histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"eshop-publicapi\"}[5m])) by (le)) * 1000","legendFormat":"p99"}
      ]
    },
    {
      "id": 30, "type": "row", "title": "k6 Load Test Results", "gridPos": {"h":1,"w":24,"x":0,"y":23}
    },
    {
      "id": 31, "type": "timeseries", "title": "k6 — HTTP Request Duration (p95)",
      "gridPos": {"h":8,"w":12,"x":0,"y":24},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {"defaults": {"unit":"ms","custom":{"lineWidth":2}}},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "targets": [{"expr":"k6_http_req_duration_p95{url=~\".*/api/.*\"}","legendFormat":"{{url}}"}]
    },
    {
      "id": 32, "type": "timeseries", "title": "k6 — Virtual Users Over Time",
      "gridPos": {"h":8,"w":12,"x":12,"y":24},
      "datasource": {"type":"prometheus","uid":"PBFA97CFB590B2093"},
      "fieldConfig": {"defaults": {"unit":"short","custom":{"lineWidth":2}}},
      "options": {"tooltip":{"mode":"multi"}},
      "targets": [{"expr":"k6_vus","legendFormat":"VUs"}]
    },
    {
      "id": 40, "type": "row", "title": "Loki — Live Logs", "gridPos": {"h":1,"w":24,"x":0,"y":32}
    },
    {
      "id": 41, "type": "logs", "title": "eShop API Logs",
      "gridPos": {"h":10,"w":24,"x":0,"y":33},
      "datasource": {"type":"loki","uid":"P8E80F9AEF21F6940"},
      "options": {"dedupStrategy":"none","enableLogDetails":true,"prettifyLogMessage":false,"showTime":true,"wrapLogMessage":true},
      "targets": [{"expr":"{container_name=\"eshop-publicapi\"}","legendFormat":""}]
    }
  ]
}
