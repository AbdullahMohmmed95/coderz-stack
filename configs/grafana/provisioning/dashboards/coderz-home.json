{
  "uid": "coderz-home",
  "title": "Coderz — Stack Home",
  "description": "One-page overview of the entire Coderz monitoring stack",
  "tags": ["home", "overview", "coderz"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "panels": [
    { "id": 100, "type": "row", "title": "Server Health", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },
    {
      "id": 1, "type": "stat", "title": "CPU",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 2, "type": "stat", "title": "RAM",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "RAM %" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 3, "type": "stat", "title": "Disk",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}) * 100", "legendFormat": "Disk %" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 4, "type": "stat", "title": "Uptime",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "dtdurations", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "node_time_seconds - node_boot_time_seconds", "legendFormat": "Uptime" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 5, "type": "stat", "title": "Load Avg (1m)",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 4 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "node_load1", "legendFormat": "Load 1m" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 6, "type": "stat", "title": "TCP Connections",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "node_netstat_Tcp_CurrEstab", "legendFormat": "TCP" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    { "id": 101, "type": "row", "title": "Kubernetes (k3s)", "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 }, "collapsed": false },
    {
      "id": 7, "type": "stat", "title": "k3s Running Pods",
      "gridPos": { "x": 0, "y": 5, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "count(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "Running" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 8, "type": "stat", "title": "k3s Nodes Ready",
      "gridPos": { "x": 4, "y": 5, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "legendFormat": "Nodes" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 9, "type": "stat", "title": "k3s Failed Pods",
      "gridPos": { "x": 8, "y": 5, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "count(kube_pod_status_phase{phase=~\"Failed|Unknown\"}) or vector(0)", "legendFormat": "Failed" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 10, "type": "stat", "title": "k3s Deployments",
      "gridPos": { "x": 12, "y": 5, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "count(kube_deployment_created)", "legendFormat": "Deployments" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    { "id": 102, "type": "row", "title": "Docker Containers", "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 }, "collapsed": false },
    {
      "id": 11, "type": "stat", "title": "Containers Running",
      "gridPos": { "x": 0, "y": 9, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "count(container_last_seen{image!=\"\",name!=\"\"})", "legendFormat": "Containers" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 12, "type": "stat", "title": "Container CPU (total)",
      "gridPos": { "x": 4, "y": 9, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(container_cpu_usage_seconds_total{image!=\"\",name!=\"\"}[5m])) * 100", "legendFormat": "Total CPU%" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 13, "type": "stat", "title": "Container Memory (total)",
      "gridPos": { "x": 8, "y": 9, "w": 4, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "sum(container_memory_usage_bytes{image!=\"\",name!=\"\"})", "legendFormat": "Total Mem" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    { "id": 103, "type": "row", "title": "Resource Trends", "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }, "collapsed": false },
    {
      "id": 14, "type": "timeseries", "title": "CPU / RAM / Disk — 30 min",
      "gridPos": { "x": 0, "y": 13, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "RAM %" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}) * 100", "legendFormat": "Disk %" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 15, "type": "timeseries", "title": "Network I/O (eth0)",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "irate(node_network_receive_bytes_total{device=~\"eth0|ens.*|enp.*\"}[5m])", "legendFormat": "RX" },
        { "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "irate(node_network_transmit_bytes_total{device=~\"eth0|ens.*|enp.*\"}[5m])", "legendFormat": "TX" }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },

    { "id": 104, "type": "row", "title": "Top Containers by Resource", "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 }, "collapsed": false },
    {
      "id": 16, "type": "bargauge", "title": "Top Containers by CPU",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 50 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "topk(8, rate(container_cpu_usage_seconds_total{image!=\"\",name!=\"\"}[5m]) * 100)", "legendFormat": "{{name}}" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "id": 17, "type": "bargauge", "title": "Top Containers by Memory",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color" },
      "fieldConfig": { "defaults": { "unit": "bytes",
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 256000000 }, { "color": "red", "value": 1000000000 }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }, "expr": "topk(8, container_memory_usage_bytes{image!=\"\",name!=\"\"})", "legendFormat": "{{name}}" }],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    }
  ]
}
